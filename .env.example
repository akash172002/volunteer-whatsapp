# ── Whapi ─────────────────────────────────────────────────────────────────────
# API token from your channel settings page on whapi.cloud
WHAPI_TOKEN=your_whapi_token_here

# ── WhatsApp number ────────────────────────────────────────────────────────────
# Your linked WhatsApp number in international format WITHOUT the + sign
# Example: +91 98765 43210 → 919876543210
PHONE_NUMBER=919876543210

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call this server
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ── Webhook ────────────────────────────────────────────────────────────────────
# Public HTTPS URL Whapi will POST events to (your server's /webhook route)
# For local development: run `node dev.js` — it starts ngrok and registers this automatically
# For production: set your deployed server URL here
WEBHOOK_URL=https://your-public-url.ngrok-free.app/webhook
