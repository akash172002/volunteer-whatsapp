# ── Whapi ─────────────────────────────────────────────────────────────────────
# API token from your Whapi channel settings page (whapi.cloud)
WHAPI_TOKEN=your_token_here

# Your WhatsApp number — international format, no + sign
# Example: +91 98765 43210 → 919876543210
PHONE_NUMBER=919876543210

# ── Server ─────────────────────────────────────────────────────────────────────
# Port this WhatsApp service runs on
PORT=3001

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call this service.
# Add your main project's dev and production URLs here.
# Default covers common frontend dev ports (React, Vite, Vue, Angular).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
